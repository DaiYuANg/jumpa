APP_NAME=jumpa

APP_SERVER_PORT=8080

# sqlite | mysql | mariadb | postgres
APP_DB_DRIVER=sqlite

# Local sqlite file for inspection.
APP_DB_DSN=file:./app.db
APP_DB_NODE_ID=0

APP_SCHEDULER_ENABLED=true
APP_SCHEDULER_HEARTBEAT_SEC=60
APP_SCHEDULER_DISTRIBUTED_ENABLED=false
APP_SCHEDULER_DISTRIBUTED_KEY_PREFIX=gocron:lock
APP_SCHEDULER_DISTRIBUTED_TTL_SEC=30

APP_VALKEY_ENABLED=false
APP_VALKEY_ADDR=127.0.0.1:6379
APP_VALKEY_PASSWORD=
APP_VALKEY_DB=0
APP_VALKEY_USE_TLS=false

APP_JWT_SECRET=change-me-in-production
APP_JWT_ISSUER=jumpa
APP_JWT_ACCESS_TTL_MIN=30
APP_JWT_REFRESH_TTL_HOUR=168

APP_IDENTITY_PROVIDER=local
# auto | pam | winlogon | opendirectory
APP_IDENTITY_OS_BACKEND=auto
APP_IDENTITY_OS_PAM_SERVICE=sshd
APP_IDENTITY_OS_DIRECTORY_NODE=/Search
APP_IDENTITY_OS_CREATE_HOME_POLICY=manual

APP_BASTION_ENABLED=true
APP_BASTION_SSH_LISTEN_ADDR=:2222
APP_BASTION_SSH_HOST_KEY_PATH=./secrets/ssh_host_ed25519_key
APP_BASTION_SSH_TRUSTED_PROXY_CIDR=
APP_BASTION_SESSION_IDLE_TIMEOUT_MIN=15
APP_BASTION_SESSION_MAX_DURATION_MIN=480
APP_BASTION_SESSION_RECORDING_DIRECTORY=./data/recordings

APP_AUDIT_STORE_COMMAND_INPUT=true
APP_AUDIT_STORE_REPLAY_STREAM=true

APP_AUTHZ_PROTECTED_PREFIX=/api
APP_AUTHZ_PUBLIC_PATHS_CSV=/api/auth/login,/api/auth/refresh,/api/health
APP_AUTHZ_AUTH_ONLY_RESOURCES_CSV=me,auth
